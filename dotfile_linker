#!/bin/bash
set -e

link_dot_file() {
    local src="$1"
    local dest="$2"

    if [ -e "$dest" ] && [ ! -L "$dest" ]; then
        mv "$dest" "${dest}.bak"
        echo "Backed up: $dest -> ${dest}.bak"
    fi

    ln -sfn "$src" "$dest"
    echo "Linked; $dest -> $src"
}

mkdir -p "$HOME/.config"

dotfiles=("bashrc" "vimrc")

for file in "${dotfiles[@]}"; do
    link_dot_file "$HOME/dotfiles/$file" "$HOME/.$file"
done

link_dot_file "$HOME/dotfiles/starship.toml" "$HOME/.config/starship.toml"

echo "Done!"
